    JPA .loop
.done:
    RTS

run_i64_suite:
    JPS _Print "Running signed 64-bit tests...\n"
    CLZ _test_index
    MIV i64_tests,_suite_ptr
    MIZ (i64_tests_end - i64_tests) / U64_RECORD_SIZE,_suite_count
    MIZ U64_RECORD_SIZE,_suite_stride
.loop:
    JPS load_case_64
    JPS run_i64_test
    CIZ 0,_compare_fail
    BNE fail_i64
    INZ _test_index
    DEZ _suite_count
    BEQ .done
    JPS advance_suite_ptr
    JPA .loop
.done:
    RTS
#endif

fail_u16:
    JPS _Print "u16 fail test "
    LDZ _test_index
    JAS _PrintHex
    JPS _Print "\n"
    JPS _WaitInput
    JPS _Prompt
    JPA stop_forever

fail_i16:
    JPS _Print "i16 fail test "
    LDZ _test_index
    JAS _PrintHex
    JPS _Print "\n"
    JPS _WaitInput
    JPS _Prompt
    JPA stop_forever

#ifdef MATHLIB_TEST_32
fail_u32:
    JPS _Print "u32 fail test "
    LDZ _test_index
    JAS _PrintHex
    JPS _Print "\n"
    JPS _WaitInput
    JPS _Prompt
    JPA stop_forever

fail_i32:
    JPS _Print "i32 fail test "
    LDZ _test_index
    JAS _PrintHex
    JPS _Print "\n"
    JPS _WaitInput
    JPS _Prompt
    JPA stop_forever
#endif

#ifdef MATHLIB64
fail_u64:
    JPS _Print "u64 fail test "
    LDZ _test_index
    JAS _PrintHex
    JPS _Print "\n"
    JPS _WaitInput
    JPS _Prompt
    JPA stop_forever

fail_i64:
    JPS _Print "i64 fail test "
    LDZ _test_index
    JAS _PrintHex
    JPS _Print "\n"
    JPS _WaitInput
    JPS _Prompt
    JPA stop_forever
#endif

stop_forever:
    JPA stop_forever

#include "mathlib.min64x4"

actual_buf:
    .16byte 0

; ---------- u16 tests ----------
u16_tests:
    .2byte 0x0000 ; A
    .2byte 0x1234 ; B
    .4byte 0x00000000 ; Expected

    .2byte 0x0001
    .2byte 0xFFFF
    .4byte 0x0000FFFF

    .2byte 0xFFFF
    .2byte 0xFFFF
    .4byte 0xFFFE0001

    .2byte 0x8000
    .2byte 0x8000
    .4byte 0x40000000

    .2byte 0x1234
    .2byte 0x5678
    .4byte 0x06260060

    .2byte 0x00FF
    .2byte 0x0101
    .4byte 0x0000FFFF
u16_tests_end:

; ---------- i16 tests ----------
i16_tests:
    .2byte 0x7FFF
    .2byte 0x0002
    .4byte 0x0000FFFE

    .2byte 0x8000
    .2byte 0x0001
    .4byte 0xFFFF8000

    .2byte 0x8000
    .2byte 0xFFFF
    .4byte 0x00008000

    .2byte 0x8000
    .2byte 0x8000
    .4byte 0x40000000

    .2byte 0xFFFF
    .2byte 0x0002
    .4byte 0xFFFFFFFE

    .2byte 0xEDCC
    .2byte 0x0003
    .4byte 0xFFFFC964
i16_tests_end:

#ifdef MATHLIB_TEST_32
; ---------- u32 tests ----------
u32_tests:
    .4byte 0x00000000
    .4byte 0x12345678
    .8byte 0x0000000000000000

    .4byte 0x00010000
    .4byte 0x00010000
    .8byte 0x0000000100000000

    .4byte 0xFFFFFFFF
    .4byte 0xFFFFFFFF
    .8byte 0xFFFFFFFE00000001

    .4byte 0x80000000
    .4byte 0x80000000
    .8byte 0x4000000000000000

    .4byte 0x0001FFFF
    .4byte 0xFFFF0001
    .8byte 0x0001FFFD0002FFFF

    .4byte 0x12345678
    .4byte 0x9ABCDEF0
    .8byte 0x0B00EA4E242D2080
u32_tests_end:

; ---------- i32 tests ----------
i32_tests:
    .4byte 0x7FFFFFFF
    .4byte 0x00000002
    .8byte 0x00000000FFFFFFFE

    .4byte 0x80000000
    .4byte 0x00000001
    .8byte 0xFFFFFFFF80000000

    .4byte 0x80000000
    .4byte 0xFFFFFFFF
    .8byte 0x0000000080000000

    .4byte 0xFFFFFFFF
    .4byte 0xFFFFFFFF
    .8byte 0x0000000000000001

    .4byte 0xFFFFFFFF
    .4byte 0x00000002
    .8byte 0xFFFFFFFFFFFFFFFE

    .4byte 0xEDCBA988
    .4byte 0x00010002
    .8byte 0xFFFFEDCB851F5310
i32_tests_end:
#endif

#ifdef MATHLIB64
; ---------- u64 tests ----------
u64_tests:
    .8byte 0x0000000000000000
    .8byte 0x123456789ABCDEF0
    .16byte 0x00000000000000000000000000000000

    .8byte 0x0000000000000001
    .8byte 0xFFFFFFFFFFFFFFFF
    .16byte 0x0000000000000000FFFFFFFFFFFFFFFF

    .8byte 0xFFFFFFFFFFFFFFFF
    .8byte 0xFFFFFFFFFFFFFFFF
    .16byte 0xFFFFFFFFFFFFFFFE0000000000000001

    .8byte 0x8000000000000000
    .8byte 0x8000000000000000
    .16byte 0x40000000000000000000000000000000

    .8byte 0x0000000100000000
    .8byte 0x0000000100000000
    .16byte 0x00000000000000010000000000000000

    .8byte 0x123456789ABCDEF0
    .8byte 0x0FEDCBA987654321
    .16byte 0x0121FA00AD77D7422236D88FE5618CF0

    .8byte 0x1122334455667788
    .8byte 0x99AABBCCDDEEFF00
    .16byte 0x0a48ddeb93f93d70479983e499807800

    .8byte 0xFFFFFFFFFFFFFFFF
    .8byte 0x0000000100000001
    .16byte 0x0000000100000000FFFFFFFEFFFFFFFF

    .8byte 0x00000000FFFFFFFF
    .8byte 0x00000000FFFFFFFF
    .16byte 0x0000000000000000FFFFFFFE00000001

    .8byte 0xFFFFFFFF00000000
    .8byte 0x00000000FFFFFFFF
    .16byte 0x00000000FFFFFFFE0000000100000000
u64_tests_end:

; ---------- i64 tests ----------
i64_tests:
    .8byte 0x7FFFFFFFFFFFFFFF
    .8byte 0x0000000000000002
    .16byte 0x0000000000000000FFFFFFFFFFFFFFFE

    .8byte 0x8000000000000000
    .8byte 0x0000000000000001
    .16byte 0xFFFFFFFFFFFFFFFF8000000000000000

    .8byte 0x8000000000000000
    .8byte 0xFFFFFFFFFFFFFFFF
    .16byte 0x00000000000000008000000000000000

    .8byte 0xFFFFFFFFFFFFFFFF
    .8byte 0xFFFFFFFFFFFFFFFF
    .16byte 0x00000000000000000000000000000001

    .8byte 0xFFFFFFFFFFFFFFFF
    .8byte 0x0000000000000002
    .16byte 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFE

    .8byte 0xEDCBA98765432110
    .8byte 0x0000000000000011
    .16byte 0xFFFFFFFFFFFFFFFECA8641FDB9753210
i64_tests_end:
#endif
