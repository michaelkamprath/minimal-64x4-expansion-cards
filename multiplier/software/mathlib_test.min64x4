#endif

run_u16_suite:
    JPS _Print "Running unsigned 16-bit tests...\n"
    CLZ _test_index
    MIV u16_tests,_suite_ptr
    MIZ (u16_tests_end - u16_tests) / U16_RECORD_SIZE,_suite_count
    MIZ U16_RECORD_SIZE,_suite_stride
.loop:
    JPS load_case_16
    JPS run_u16_test
    CIZ 0,_compare_fail
    BNE fail_u16
    INZ _test_index
    DEZ _suite_count
    BEQ .done
    JPS advance_suite_ptr
    JPA .loop
.done:
    RTS

run_i16_suite:
    JPS _Print "Running signed 16-bit tests...\n"
    CLZ _test_index
    MIV i16_tests,_suite_ptr
    MIZ (i16_tests_end - i16_tests) / U16_RECORD_SIZE,_suite_count
    MIZ U16_RECORD_SIZE,_suite_stride
.loop:
    JPS load_case_16
    JPS run_i16_test
    CIZ 0,_compare_fail
    BNE fail_i16
    INZ _test_index
    DEZ _suite_count
    BEQ .done
    JPS advance_suite_ptr
    JPA .loop
.done:
    RTS

#ifdef MATHLIB_TEST_32
run_u32_suite:
    JPS _Print "Running unsigned 32-bit tests...\n"
    CLZ _test_index
    MIV u32_tests,_suite_ptr
    MIZ (u32_tests_end - u32_tests) / U32_RECORD_SIZE,_suite_count
    MIZ U32_RECORD_SIZE,_suite_stride
.loop:
    JPS load_case_32
    JPS run_u32_test
    CIZ 0,_compare_fail
    BNE fail_u32
    INZ _test_index
    DEZ _suite_count
    BEQ .done
    JPS advance_suite_ptr
    JPA .loop
.done:
    RTS

run_i32_suite:
    JPS _Print "Running signed 32-bit tests...\n"
    CLZ _test_index
    MIV i32_tests,_suite_ptr
    MIZ (i32_tests_end - i32_tests) / U32_RECORD_SIZE,_suite_count
    MIZ U32_RECORD_SIZE,_suite_stride
.loop:
    JPS load_case_32
    JPS run_i32_test
    CIZ 0,_compare_fail
    BNE fail_i32
    INZ _test_index
    DEZ _suite_count
    BEQ .done
    JPS advance_suite_ptr
    JPA .loop
.done:
    RTS
#endif

#ifdef MATHLIB64
run_u64_suite:
    JPS _Print "Running unsigned 64-bit tests...\n"
    CLZ _test_index
    MIV u64_tests,_suite_ptr
    MIZ (u64_tests_end - u64_tests) / U64_RECORD_SIZE,_suite_count
    MIZ U64_RECORD_SIZE,_suite_stride
.loop:
    JPS load_case_64
    JPS run_u64_test
    CIZ 0,_compare_fail
    BNE fail_u64
    INZ _test_index
    DEZ _suite_count
    BEQ .done
