#require "slu4-min64x4-asm >= 1.1.0"
#use-scope "mathlib"

#ifdef MATHLIB32
#define MATHLIB_TEST_32 1
#endif
#ifdef MATHLIB64
#define MATHLIB_TEST_32 1
#endif

; Math library correctness tests for:
;   ml_multiply_u16, ml_multiply_i16
;   ml_multiply_u32, ml_multiply_i32
;   ml_multiply_u64, ml_multiply_i64
;
; Intended compile examples:
;   bespokeasm compile -c /tmp/slu4-minimal-64x4.yaml -n -p -t intel_hex multiplier/software/mathlib_test.min64x4
;   bespokeasm compile -c /tmp/slu4-minimal-64x4.yaml -n -p -t intel_hex -D MATHLIB32 multiplier/software/mathlib_test.min64x4
;   bespokeasm compile -c /tmp/slu4-minimal-64x4.yaml -n -p -t intel_hex -D MATHLIB64 multiplier/software/mathlib_test.min64x4
;   bespokeasm compile -c /tmp/slu4-minimal-64x4.yaml -n -p -t intel_hex -D USE_ACCELERATOR multiplier/software/mathlib_test.min64x4
;   bespokeasm compile -c /tmp/slu4-minimal-64x4.yaml -n -p -t intel_hex -D MATHLIB32 -D USE_ACCELERATOR multiplier/software/mathlib_test.min64x4
;   bespokeasm compile -c /tmp/slu4-minimal-64x4.yaml -n -p -t intel_hex -D MATHLIB64 -D USE_ACCELERATOR multiplier/software/mathlib_test.min64x4

U16_RECORD_SIZE = 8
U32_RECORD_SIZE = 16
U64_RECORD_SIZE = 32

.memzone ZERO_PAGE_APPS
#mute
_test_index:   .byte 0
_compare_fail: .byte 0
_count:        .byte 0
_tmp_count:    .byte 0
_suite_count:  .byte 0
_suite_stride: .byte 0

_a_base:       .2byte 0
_b_base:       .2byte 0
_expect_base:  .2byte 0

_suite_ptr:    .2byte 0
_expect_ptr:   .2byte 0
_actual_ptr:   .2byte 0
#emit

.memzone USER_APPS
main:
    SPINIT
    JPS _Clear
    MIZ 0,_XPos
    MIZ 0,_YPos
    JPS _Print "mathlib API tests\n"

    JPS run_u16_suite
    JPS run_i16_suite
#ifdef MATHLIB_TEST_32
    JPS run_u32_suite
    JPS run_i32_suite
#endif
#ifdef MATHLIB64
    JPS run_u64_suite
    JPS run_i64_suite
#endif

    JPS _Print "All mathlib tests passed\n"
    JPS _WaitInput
    JPS _Prompt
    JPA stop_forever

; Compare expected bytes against actual_buf over _count bytes (LSB -> MSB)
compare_actual:
    CLZ _compare_fail
    MIV actual_buf,_actual_ptr

    LDZ _count
    STZ _tmp_count
.loop:
    LDT _expect_ptr
    CPR _actual_ptr
    BNE .mismatch
    INV _expect_ptr
    INV _actual_ptr
    DEZ _tmp_count
    BNE .loop
    RTS

.mismatch:
    INZ _compare_fail
    RTS

; Advance _suite_ptr by _suite_stride bytes.
advance_suite_ptr:
    LDZ _suite_stride
    STZ _tmp_count
.loop:
    INV _suite_ptr
    DEZ _tmp_count
    BNE .loop
    RTS

; Load _a_base, _b_base, _expect_base from current 16-bit record at _suite_ptr.
load_case_16:
    MVV _suite_ptr,_a_base
    MVV _suite_ptr,_b_base
    INV _b_base
    INV _b_base
    MVV _b_base,_expect_base
    INV _expect_base
    INV _expect_base
    RTS

; Load _a_base, _b_base, _expect_base from current 32-bit record at _suite_ptr.
load_case_32:
    MVV _suite_ptr,_a_base
    MVV _suite_ptr,_b_base
    INV _b_base
    INV _b_base
    INV _b_base
    INV _b_base
    MVV _b_base,_expect_base
    INV _expect_base
    INV _expect_base
    INV _expect_base
    INV _expect_base
    RTS

; Load _a_base, _b_base, _expect_base from current 64-bit record at _suite_ptr.
load_case_64:
    MVV _suite_ptr,_a_base
    MVV _suite_ptr,_b_base
    INV _b_base
    INV _b_base
    INV _b_base
    INV _b_base
    INV _b_base
    INV _b_base
    INV _b_base
    INV _b_base
    MVV _b_base,_expect_base
    INV _expect_base
    INV _expect_base
    INV _expect_base
    INV _expect_base
    INV _expect_base
    INV _expect_base
    INV _expect_base
    INV _expect_base
    RTS

run_u16_test:
    MVV _a_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    MVV _b_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    JPS ml_multiply_u16

    PLS
    STB actual_buf+3
    PLS
    STB actual_buf+2
    PLS
    STB actual_buf+1
    PLS
    STB actual_buf+0

    MVV _expect_base,_expect_ptr
    MIZ 4,_count
    JPS compare_actual
    RTS

run_i16_test:
    MVV _a_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    MVV _b_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    JPS ml_multiply_i16

    PLS
    STB actual_buf+3
    PLS
    STB actual_buf+2
    PLS
    STB actual_buf+1
    PLS
    STB actual_buf+0

    MVV _expect_base,_expect_ptr
    MIZ 4,_count
    JPS compare_actual
    RTS

#ifdef MATHLIB_TEST_32
run_u32_test:
    MVV _a_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    MVV _b_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    JPS ml_multiply_u32

    PLS
    STB actual_buf+7
    PLS
    STB actual_buf+6
    PLS
    STB actual_buf+5
    PLS
    STB actual_buf+4
    PLS
    STB actual_buf+3
    PLS
    STB actual_buf+2
    PLS
    STB actual_buf+1
    PLS
    STB actual_buf+0

    MVV _expect_base,_expect_ptr
    MIZ 8,_count
    JPS compare_actual
    RTS

run_i32_test:
    MVV _a_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    MVV _b_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    JPS ml_multiply_i32

    PLS
    STB actual_buf+7
    PLS
    STB actual_buf+6
    PLS
    STB actual_buf+5
    PLS
    STB actual_buf+4
    PLS
    STB actual_buf+3
    PLS
    STB actual_buf+2
    PLS
    STB actual_buf+1
    PLS
    STB actual_buf+0

    MVV _expect_base,_expect_ptr
    MIZ 8,_count
    JPS compare_actual
    RTS
#endif

#ifdef MATHLIB64
run_u64_test:
    MVV _a_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    MVV _b_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    JPS ml_multiply_u64

    PLS
    STB actual_buf+15
    PLS
    STB actual_buf+14
    PLS
    STB actual_buf+13
    PLS
    STB actual_buf+12
    PLS
    STB actual_buf+11
    PLS
    STB actual_buf+10
    PLS
    STB actual_buf+9
    PLS
