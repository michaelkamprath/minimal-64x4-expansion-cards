    PLS
    STB actual_buf+2
    PLS
    STB actual_buf+1
    PLS
    STB actual_buf+0

    MVV _expect_base,_expect_ptr
    MIZ 16,_count
    JPS compare_actual
    RTS

run_i64_test:
    MVV _a_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS

    MVV _b_base,_actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
    PHS
    INV _actual_ptr
    LDT _actual_ptr
